# Local (non-Docker) dev defaults — the app falls back to these if unset
DATABASE_URL=postgresql+psycopg://patch:patch@localhost:5432/patch
REDIS_URL=redis://localhost:6379/0

# Host directory mounted into the api container at /repos (docker compose)
REPOS_DIR=~/MyProjects

# How long OSV.dev responses stay cached (seconds)
OSV_CACHE_TTL_SECONDS=86400

# Optional GitHub PAT fallback for scanning (users' OAuth tokens are preferred)
GITHUB_TOKEN=

# --- Auth (leave all empty to run in single-user dev mode, no login) ---
# Random string; signs session cookies. Required in production:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Public URL of this instance; OAuth callback URLs are derived from it
BASE_URL=http://localhost:8000

# GitHub OAuth app (github.com -> Settings -> Developer settings -> OAuth Apps)
#   Authorization callback URL: $BASE_URL/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth client (console.cloud.google.com -> APIs & Services -> Credentials)
#   Authorized redirect URI: $BASE_URL/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where the dashboard's folder browser starts (defaults: /repos in Docker, else $HOME)
BROWSE_ROOT=

