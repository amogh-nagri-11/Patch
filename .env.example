# Local (non-Docker) dev defaults — the app falls back to these if unset
DATABASE_URL=postgresql+psycopg://patch:patch@localhost:5432/patch
REDIS_URL=redis://localhost:6379/0

# Host directory mounted into the api container at /repos (docker compose)
REPOS_DIR=~/MyProjects

# How long OSV.dev responses stay cached (seconds)
OSV_CACHE_TTL_SECONDS=86400

# Optional GitHub PAT — needed for private repos, raises API rate limit 60 -> 5000/hr
GITHUB_TOKEN=

# Where the dashboard's folder browser starts (defaults: /repos in Docker, else $HOME)
BROWSE_ROOT=

